# Runtime — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# JWT secret used to sign long-lived MCP bearer tokens.
# Grab the legacy HS256 secret from
# Supabase Dashboard → Project Settings → API → JWT Settings → "JWT Secret".
# Must be the same value the project uses to validate JWTs, otherwise
# RLS-scoped queries via the MCP token will fail.
SUPABASE_JWT_SECRET=

# Runtime — legacy fallback (prefer PUBLISHABLE_KEY)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Tooling — only needed when regenerating database.types.ts
# via `bun gen:types`. Grab a personal access token from
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Optional — KV (if/when you wire it up)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional — OpenTelemetry export to Sensorium (sensorium.zyx.tw). Unset by
# default: instrumentation.ts's register() no-ops entirely when
# OTEL_EXPORTER_OTLP_ENDPOINT is absent (plain `bun dev`/`bun test`).
# OTEL_EXPORTER_OTLP_ENDPOINT=https://sensorium.zyx.tw
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <ingest-token>
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=ai-winlab,service.name=mcp
# OTEL_SERVICE_NAME=mcp
