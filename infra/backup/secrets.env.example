# Copy to /etc/aioffice-backup/secrets.env on the cron VM and fill in.
# chmod 600 — service-role key + DB password live here.

# Pooler URL from Supabase dashboard → Settings → Database → Connection string
# (the "session" or "transaction" pooler string with the real password substituted in).
DATABASE_URL="postgresql://postgres.hwezfbhjcetpezfuvelf:<DB_PASSWORD>@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Service role key from Supabase dashboard → Settings → API
# Used by storage backup to enumerate + download buckets.
SUPABASE_URL="https://hwezfbhjcetpezfuvelf.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service_role_jwt>"

# Where backups live + how long to keep them
BACKUP_ROOT="/var/backups/aioffice"
RETENTION_DAYS=14
